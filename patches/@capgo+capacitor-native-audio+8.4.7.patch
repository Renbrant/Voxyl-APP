+        queueItem.title = optString(item, "title", "");
+        queueItem.podcastTitle = optString(item, "podcastTitle", optString(item, "feedTitle", optString(item, "showTitle", "")));
+        queueItem.audioUrl = optString(item, "audioUrl", optString(item, "url", optString(item, "assetPath", "")));
+        queueItem.artworkUrl = optString(item, "artworkUrl", optString(item, "image", optString(item, "podcastImage", "")));
+        queueItem.playlistId = optString(item, "playlistId", optString(item, "playlist_id", ""));
+        queueItem.index = item.optInt("index", fallbackIndex);
+        return queueItem;
+    }
+
+    private String optString(JSONObject item, String key, String fallback) {
