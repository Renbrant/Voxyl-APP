+                    }
+                }
+            }
+            queueAutoplayEnabled = autoplay;
+            if (queueItems.isEmpty()) {
+                currentQueueIndex = -1;
+            } else {
+                currentQueueIndex = Math.max(0, Math.min(requestedIndex, queueItems.size() - 1));
+            }
+        }
+        Log.d(TAG, AUDIO_NEXT_PREFIX + " " + reason + " size=" + queueItems.size() + " autoplay=" + queueAutoplayEnabled);
+        Log.d(TAG, AUDIO_NEXT_PREFIX + " current index set " + currentQueueIndex);
+    }
